  <diagram id="6JiFPfwmZ1HIq7bXwpDS" name="Trang-6">
    <mxGraphModel dx="1030" dy="596" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\nclass Account{\n+username : String\n+password : String\n+role : String\n\n+login()\n+logout()\n+changePassword()\n}\n\nclass Student{\n+studentID : String\n+fullName : String\n+dateOfBirth : Date\n+gender : String\n+email : String\n\n+viewScore()\n}\n\nclass Lecturer{\n+lecturerID : String\n+fullName : String\n+degree : String\n\n+inputScore()\n+updateScore()\n}\n\nclass Department{\n+departmentID : String\n+departmentName : String\n}\n\nclass Subject{\n+subjectID : String\n+subjectName : String\n+credits : int\n}\n\nclass Semester{\n+semesterID : String\n+semesterName : String\n+academicYear : String\n}\n\nclass ClassSection{\n+classID : String\n+className : String\n}\n\nclass Score{\n+scoreID : String\n+attendanceScore : float\n+midtermScore : float\n+finalScore : float\n+totalScore : float\n\n+calculateTotal()\n}\n\nclass Transcript{\n+transcriptID : String\n+GPA : float\n+academicRank : String\n\n+calculateGPA()\n}\n\nAccount &lt;|-- Student\nAccount &lt;|-- Lecturer\n\nDepartment \&quot;1\&quot; -- \&quot;0..*\&quot; Student\nDepartment \&quot;1\&quot; -- \&quot;0..*\&quot; Lecturer\n\nSemester \&quot;1\&quot; -- \&quot;0..*\&quot; ClassSection\n\nLecturer \&quot;1\&quot; -- \&quot;0..*\&quot; ClassSection\n\nClassSection \&quot;1\&quot; -- \&quot;0..*\&quot; Student\n\nSubject \&quot;1\&quot; -- \&quot;0..*\&quot; Score\n\nStudent \&quot;1\&quot; -- \&quot;0..*\&quot; Score\n\nStudent \&quot;1\&quot; *-- \&quot;1\&quot; Transcript\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="CtT9F7ifZmxjP-vSDeDU-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="868" width="542" x="250" y="60" as="geometry" />
          </mxCell>
        </UserObject>
