  <diagram id="7CeyiNEMnYiUcPu98y2R" name="Trang-9">
    <mxGraphModel dx="1030" dy="596" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nleft to right direction\n\nactor Student\nactor Lecturer\nactor Administrator\n\nrectangle \&quot;Hệ thống quản lý điểm &amp; kết quả học tập\&quot; {\n\nusecase \&quot;Đăng nhập\&quot; as UC1\nusecase \&quot;Đăng xuất\&quot; as UC2\nusecase \&quot;Đổi mật khẩu\&quot; as UC3\n\nusecase \&quot;Xem thông tin cá nhân\&quot; as UC4\nusecase \&quot;Xem bảng điểm\&quot; as UC5\nusecase \&quot;Xem GPA\&quot; as UC6\nusecase \&quot;Xem học lực\&quot; as UC7\nusecase \&quot;In bảng điểm\&quot; as UC8\n\nusecase \&quot;Xem danh sách lớp\&quot; as UC9\nusecase \&quot;Nhập điểm\&quot; as UC10\nusecase \&quot;Cập nhật điểm\&quot; as UC11\nusecase \&quot;Gửi điểm xét duyệt\&quot; as UC12\n\nusecase \&quot;Quản lý sinh viên\&quot; as UC13\nusecase \&quot;Quản lý giảng viên\&quot; as UC14\nusecase \&quot;Quản lý môn học\&quot; as UC15\nusecase \&quot;Quản lý học kỳ\&quot; as UC16\nusecase \&quot;Quản lý tài khoản\&quot; as UC17\n\nusecase \&quot;Xuất báo cáo\&quot; as UC18\nusecase \&quot;Thống kê sinh viên đạt\&quot; as UC19\nusecase \&quot;Thống kê sinh viên học lại\&quot; as UC20\nusecase \&quot;Xét học bổng\&quot; as UC21\nusecase \&quot;Cảnh báo học vụ\&quot; as UC22\n\nusecase \&quot;Tính GPA\&quot; as UC23\n}\n\nStudent --&gt; UC1\nStudent --&gt; UC2\nStudent --&gt; UC3\nStudent --&gt; UC4\nStudent --&gt; UC5\nStudent --&gt; UC6\nStudent --&gt; UC7\nStudent --&gt; UC8\n\nLecturer --&gt; UC1\nLecturer --&gt; UC2\nLecturer --&gt; UC3\nLecturer --&gt; UC9\nLecturer --&gt; UC10\nLecturer --&gt; UC11\nLecturer --&gt; UC12\n\nAdministrator --&gt; UC1\nAdministrator --&gt; UC2\nAdministrator --&gt; UC13\nAdministrator --&gt; UC14\nAdministrator --&gt; UC15\nAdministrator --&gt; UC16\nAdministrator --&gt; UC17\nAdministrator --&gt; UC18\nAdministrator --&gt; UC19\nAdministrator --&gt; UC20\nAdministrator --&gt; UC21\nAdministrator --&gt; UC22\n\nUC6 .&gt; UC23 : &lt;&lt;include&gt;&gt;\nUC7 .&gt; UC23 : &lt;&lt;include&gt;&gt;\nUC21 .&gt; UC23 : &lt;&lt;include&gt;&gt;\nUC22 .&gt; UC23 : &lt;&lt;include&gt;&gt;\n\nUC8 .&gt; UC5 : &lt;&lt;include&gt;&gt;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="U87_UeZ-lZCW2mCEmWWO-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
