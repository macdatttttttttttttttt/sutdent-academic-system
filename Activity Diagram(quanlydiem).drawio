  <diagram id="7FXAv4I8kooGFeGJnbZx" name="Trang-3">
    <mxGraphModel dx="1030" dy="596" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\nactor Lecturer\n\nboundary LoginForm\ncontrol ScoreController\ndatabase Database\n\nLecturer -&gt; LoginForm : Đăng nhập\n\nLoginForm -&gt; Database : Kiểm tra tài khoản\n\nalt Tài khoản hợp lệ\n\nDatabase --&gt; LoginForm : Thành công\n\nLoginForm --&gt; Lecturer : Đăng nhập thành công\n\nLecturer -&gt; ScoreController : Chọn lớp học phần\n\nScoreController -&gt; Database : Lấy danh sách SV\n\nDatabase --&gt; ScoreController : Danh sách SV\n\nScoreController --&gt; Lecturer : Hiển thị danh sách\n\nloop Nhập điểm cho từng sinh viên\n\nLecturer -&gt; ScoreController : Nhập điểm\n\nScoreController -&gt; Database : Kiểm tra dữ liệu\n\nalt Điểm hợp lệ\n\nDatabase --&gt; ScoreController : OK\n\nScoreController -&gt; Database : Lưu điểm\n\nDatabase --&gt; ScoreController : Thành công\n\nelse Điểm không hợp lệ\n\nDatabase --&gt; ScoreController : Lỗi\n\nScoreController --&gt; Lecturer : Nhập lại\n\nend\n\nend\n\nScoreController --&gt; Lecturer : Hoàn tất\n\nelse Sai tài khoản\n\nDatabase --&gt; LoginForm : Thất bại\n\nLoginForm --&gt; Lecturer : Thông báo lỗi\n\nend\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="y2kLjaOd-B8Shmk3s8g6-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="799" width="521" x="210" y="40" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="aHf51_6Tr8nRFReK8zXv" name="Trang-4">
    <mxGraphModel dx="1030" dy="596" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
