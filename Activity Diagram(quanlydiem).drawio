      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\nleft to right direction\n\n[*] --&gt; ChuaNhapDiem\n\nstate \&quot;Chưa nhập điểm\&quot; as ChuaNhapDiem\nstate \&quot;Đang nhập điểm\&quot; as DangNhapDiem\nstate \&quot;Đã lưu tạm\&quot; as DaLuuTam\nstate \&quot;Đã gửi duyệt\&quot; as DaGuiDuyet\nstate \&quot;Đã duyệt\&quot; as DaDuyet\nstate \&quot;Đã công bố\&quot; as DaCongBo\nstate \&quot;Hoàn tất\&quot; as HoanTat\n\nChuaNhapDiem --&gt; DangNhapDiem : Bắt đầu nhập\n\nDangNhapDiem --&gt; DaLuuTam : Lưu tạm\n\nDaLuuTam --&gt; DaGuiDuyet : Gửi duyệt\n\nDaGuiDuyet --&gt; DaDuyet : Phòng đào tạo duyệt\n\nDaDuyet --&gt; DaCongBo : Công bố điểm\n\nDaCongBo --&gt; HoanTat\n\nHoanTat --&gt; [*]\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="fU8cBvY8hTB6Pr2gSy7j-4">
